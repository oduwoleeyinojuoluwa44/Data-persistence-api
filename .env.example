# Database
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/insighta_labs
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insighta_labs
PORT=3000

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://data-persistence-api-psi.vercel.app/api/v1/auth/github/callback

# JWT Secrets
ACCESS_TOKEN_SECRET=replace_with_strong_secret
REFRESH_TOKEN_SECRET=replace_with_strong_secret

# RBAC bootstrap (comma-separated github usernames to auto-elevate)
ADMIN_GITHUB_USERNAMES=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://web-portal-deploy.vercel.app

# Runtime
NODE_ENV=development

# Rate limits (per minute)
AUTH_RATE_LIMIT_PER_MINUTE=30
API_RATE_LIMIT_PER_MINUTE=60

# Stage 4B tuning
PROFILE_QUERY_CACHE_TTL_SECONDS=60
CSV_INGEST_CHUNK_SIZE=1000
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
